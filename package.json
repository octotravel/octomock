{
  "name": "octomock",
  "version": "1.0.3",
  "description": "",
  "license": "MIT",
  "author": "",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "build:dry": "tsc --noEmit",
    "build:dry:ci": "tsc --noEmit --tsBuildInfoFile ./.cache/tsc",
    "esbuild": "tsx ./esbuild.config.ts",
    "dev": "tsx watch ./src/index.ts",
    "check": "npm run build:dry && npm run format && npm run lint",
    "fix": "biome check --write .",
    "format": "biome format",
    "format:fix": "biome format --write .",
    "lint": "biome lint",
    "lint:fix": "biome lint --write .",
    "test": "VITE_CJS_IGNORE_WARNING=true vitest run --config ./vitest.config.ts",
    "test:coverage": "VITE_CJS_IGNORE_WARNING=true vitest run --config ./vitest.config.ts --coverage"
  },
  "dependencies": {
    "@koa/cors": "5.0.0",
    "@koa/router": "13.1.0",
    "@octocloud/generators": "1.0.12",
    "@octocloud/types": "1.5.43",
    "better-sqlite3": "11.10.0",
    "date-fns": "2.29.1",
    "date-fns-tz": "1.3.6",
    "dotenv": "16.5.0",
    "isomorphic-fetch": "^3.0.0",
    "koa": "3.0.0",
    "koa-body": "6.0.1",
    "koa-bodyparser": "4.4.1",
    "prando": "6.0.1",
    "ramda": "0.30.1",
    "yup": "0.32.11"
  },
  "devDependencies": {
    "@biomejs/biome": "2.0.0",
    "@types/better-sqlite3": "7.6.13",
    "@types/koa": "2.15.0",
    "@types/koa__cors": "5.0.0",
    "@types/koa__router": "12.0.4",
    "@types/ramda": "0.30.2",
    "@vitest/coverage-v8": "3.1.4",
    "esbuild": "0.25.5",
    "tsx": "4.16.2",
    "typescript": "5.8.3",
    "vitest": "3.1.4",
    "vitest-mock-extended": "3.1.0"
  }
}
